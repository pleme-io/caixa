{
  "name": "tree-sitter-caixa",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for tatara-lisp / caixa sources",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "parser",
    "lexer",
    "tree-sitter",
    "tatara-lisp",
    "caixa",
    "lisp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pleme-io/caixa"
  },
  "author": "pleme-io",
  "dependencies": {
    "node-addon-api": "^7.1.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "build": "tree-sitter build",
    "test": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "source.caixa",
      "file-types": [
        "caixa",
        "lisp",
        "lsp"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "locals": [
        "queries/locals.scm"
      ],
      "injections": [
        "queries/injections.scm"
      ]
    }
  ]
}
